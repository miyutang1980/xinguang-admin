      "id": "node-read",
      "name": "讀取員工帳號表",
      "type": "n8n-nodes-base.googleSheets",
      "typeVersion": 4.4,
      "position": [
        800,
        520
      ],
      "credentials": {
        "googleSheetsOAuth2Api": {
          "id": "REPLACE_WITH_YOUR_SHEETS_CRED_ID",
          "name": "Google Sheets account"
        }
      }
    },
    {
      "parameters": {
        "jsCode": "// 取出原始輸入\nconst input = $('解析請求').first().json;\nconst rows = $input.all();\n\nconst { action, adminUser, adminPass, targetUser, newPassword, newStatus, newAccount } = input;\n\n// 找 admin 與 target\nlet adminRow = null;\nlet targetRow = null;\nlet targetRowNumber = null;\nlet maxEmpId = 0;\n\nfor (const r of rows) {\n  const j = r.json;\n  const account = String(j['帳號'] || '').trim().toLowerCase();\n  if (account === adminUser) adminRow = j;\n  if (account === targetUser) {\n    targetRow = j;\n    targetRowNumber = j.row_number;\n  }\n  // 計算員工編號最大值（純數字），用於自動產生新編號\n  const eid = String(j['員工編號'] || '').trim();\n  const m = eid.match(/(\\d+)/);\n  if (m) {\n    const n = parseInt(m[1], 10);\n    if (!isNaN(n) && n > maxEmpId) maxEmpId = n;\n  }\n}\n\n// 驗證 admin\nif (!adminRow) return [{ json: { _stage: 'error', error: '管理員帳號不存在' } }];\nif (String(adminRow['密碼'] || '') !== adminPass) return [{ json: { _stage: 'error', error: '管理員密碼錯誤' } }];\nif (String(adminRow['角色'] || '').trim().toLowerCase() !== 'admin') return [{ json: { _stage: 'error', error: '此帳號無管理員權限' } }];\nif (String(adminRow['狀態'] || '').trim() !== '啟用') return [{ json: { _stage: 'error', error: '管理員帳號已停用' } }];\n\n// list\nif (action === 'list') {\n  const list = rows.map(r => {\n    const x = r.json;\n    return {\n      account: String(x['帳號'] || '').trim(),\n      name: String(x['員工姓名'] || '').trim(),\n      role: String(x['角色'] || '').trim(),\n      title: String(x['職稱'] || '').trim(),\n      status: String(x['狀態'] || '').trim(),\n      lastLogin: String(x['最後登入'] || '').trim(),\n      note: String(x['備註'] || '').trim()\n    };\n  });\n  return [{ json: { _stage: 'list', list } }];\n}\n\n// createAccount\nif (action === 'createAccount') {\n  const a = newAccount || {};\n  const acct = String(a.account || '').trim().toLowerCase();\n  const nm = String(a.name || '').trim();\n  const pwd = String(a.password || '').trim();\n  const role = String(a.role || 'staff').trim().toLowerCase();\n  const title = String(a.title || '').trim();\n  if (!acct || !pwd || !nm) return [{ json: { _stage: 'error', error: '帳號、姓名、密碼皆為必填' } }];\n  if (pwd.length < 4) return [{ json: { _stage: 'error', error: '密碼至少 4 字元' } }];\n  // 重複檢查\n  for (const r of rows) {\n    if (String(r.json['帳號'] || '').trim().toLowerCase() === acct) {\n      return [{ json: { _stage: 'error', error: '帳號已存在：' + acct } }];\n    }\n  }\n  const newEmpId = 'E' + String(maxEmpId + 1).padStart(3, '0');\n  return [{ json: {\n    _stage: 'append',\n    targetName: nm,\n    field: '新增',\n    '員工編號': newEmpId,\n    '員工姓名': nm,\n    '帳號': acct,\n    '密碼': pwd,\n    '角色': role,\n    '職稱': title,\n    '狀態': '啟用',\n    '最後登入': '',\n    '備註': ''\n  } }];\n}\n\n// 以下動作都要 target\nif (!targetUser) return [{ json: { _stage: 'error', error: '缺少要修改的帳號' } }];\nif (!targetRow) return [{ json: { _stage: 'error', error: '找不到帳號：' + targetUser } }];\n\nif (action === 'deleteAccount') {\n  if (targetUser === adminUser) return [{ json: { _stage: 'error', error: '不能刪除自己的帳號' } }];\n  return [{ json: {\n    _stage: 'delete',\n    row_number: targetRowNumber,\n    targetName: String(targetRow['員工姓名'] || '').trim(),\n    field: '刪除',\n    '帳號': targetRow['帳號']\n  } }];\n}\n\nif (action === 'changePassword') {\n  if (!newPassword || newPassword.length < 4) return [{ json: { _stage: 'error', error: '新密碼至少 4 字元' } }];\n  return [{ json: {\n    _stage: 'update',\n    row_number: targetRowNumber,\n    targetName: String(targetRow['員工姓名'] || '').trim(),\n    field: '密碼',\n    '員工編號': targetRow['員工編號'],\n    '員工姓名': targetRow['員工姓名'],\n    '帳號': targetRow['帳號'],\n    '密碼': newPassword,\n    '角色': targetRow['角色'],\n    '職稱': targetRow['職稱'],\n    '狀態': targetRow['狀態'],\n    '最後登入': targetRow['最後登入'],\n    '備註': targetRow['備註']\n  } }];\n}\n\nif (action === 'changeStatus') {\n  if (!['啟用', '停用'].includes(newStatus)) return [{ json: { _stage: 'error', error: '狀態須為「啟用」或「停用」' } }];\n  if (targetUser === adminUser && newStatus === '停用') return [{ json: { _stage: 'error', error: '不能停用自己的管理員帳號' } }];\n  return [{ json: {\n    _stage: 'update',\n    row_number: targetRowNumber,\n    targetName: String(targetRow['員工姓名'] || '').trim(),\n    field: '狀態',\n    '員工編號': targetRow['員工編號'],\n    '員工姓名': targetRow['員工姓名'],\n    '帳號': targetRow['帳號'],\n    '密碼': targetRow['密碼'],\n    '角色': targetRow['角色'],\n    '職稱': targetRow['職稱'],\n    '狀態': newStatus,\n    '最後登入': targetRow['最後登入'],\n    '備註': targetRow['備註']\n  } }];\n}\n\nreturn [{ json: { _stage: 'error', error: '未知 action：' + action } }];"
      },
