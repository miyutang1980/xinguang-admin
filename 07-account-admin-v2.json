      "parameters": {
        "jsCode": "// 解析請求\nconst body = $input.first().json.body || $input.first().json;\nconst action = String(body.action || '').trim();\nconst adminUser = String(body.adminUser || '').trim().toLowerCase();\nconst adminPass = String(body.adminPass || '');\nconst targetUser = String(body.targetUser || '').trim().toLowerCase();\nconst newPassword = body.newPassword !== undefined && body.newPassword !== null ? String(body.newPassword) : null;\nconst newStatus = body.newStatus !== undefined && body.newStatus !== null ? String(body.newStatus).trim() : null;\nconst newAccount = body.newAccount && typeof body.newAccount === 'object' ? body.newAccount : null;\n\nif (!action) return [{ json: { _stage: 'error', error: '缺少 action 參數' } }];\nif (!adminUser || !adminPass) return [{ json: { _stage: 'error', error: '缺少管理員帳密' } }];\n\nreturn [{ json: { _stage: 'ok', action, adminUser, adminPass, targetUser, newPassword, newStatus, newAccount } }];"
      },
